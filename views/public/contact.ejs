<%- include('../partials/header') %>

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-bg">
        <div class="gradient-orb gradient-orb-1"></div>
        <div class="gradient-orb gradient-orb-2"></div>
    </div>
    <div class="container">
        <div class="page-hero-content">
            <span class="section-tag">Bize Yazın</span>
            <h1 class="page-hero-title">İletişim</h1>
            <p class="page-hero-subtitle">Projeleriniz, sorularınız veya iş birliği teklifleriniz için bize ulaşın.</p>
        </div>
    </div>
</section>

<!-- İletişim Bölümü -->
<section class="contact-section section">
    <div class="container">
        <div class="contact-grid">
            <!-- Sol: İletişim Formu -->
            <div class="contact-form-col">
                <div class="contact-form-card glass-card">
                    <h2 class="contact-form-title">Bize Mesaj Gönderin</h2>
                    <p class="contact-form-subtitle">Formu doldurun, en kısa sürede size dönüş yapalım.</p>

                    <form id="contactForm" class="contact-form">
                        <div class="form-group">
                            <label for="name" class="form-label">Ad Soyad <span class="required">*</span></label>
                            <div class="input-wrapper">
                                <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                                <input type="text" id="name" name="name" class="form-input" placeholder="Adınız ve soyadınız" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="email" class="form-label">E-posta <span class="required">*</span></label>
                            <div class="input-wrapper">
                                <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                    <polyline points="22,6 12,13 2,6"/>
                                </svg>
                                <input type="email" id="email" name="email" class="form-input" placeholder="ornek@email.com" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="phone" class="form-label">Telefon</label>
                            <div class="input-wrapper">
                                <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                </svg>
                                <input type="tel" id="phone" name="phone" class="form-input" placeholder="+90 (5XX) XXX XX XX">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="subject" class="form-label">Konu <span class="required">*</span></label>
                            <div class="input-wrapper">
                                <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="4" y1="9" x2="20" y2="9"/>
                                    <line x1="4" y1="15" x2="20" y2="15"/>
                                    <line x1="10" y1="3" x2="8" y2="21"/>
                                    <line x1="16" y1="3" x2="14" y2="21"/>
                                </svg>
                                <input type="text" id="subject" name="subject" class="form-input" placeholder="Mesaj konusu" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="message" class="form-label">Mesaj <span class="required">*</span></label>
                            <textarea id="message" name="message" class="form-textarea" rows="5" placeholder="Mesajınızı buraya yazın..." required></textarea>
                        </div>

                        <div id="formMessage" class="form-message" style="display: none;"></div>

                        <button type="submit" class="btn btn-primary btn-block" id="submitBtn">
                            <span class="btn-text">Mesajı Gönder</span>
                            <span class="btn-loader" style="display: none;">
                                <svg class="spinner" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="2" x2="12" y2="6"/>
                                    <line x1="12" y1="18" x2="12" y2="22"/>
                                    <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
                                    <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
                                    <line x1="2" y1="12" x2="6" y2="12"/>
                                    <line x1="18" y1="12" x2="22" y2="12"/>
                                    <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/>
                                    <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
                                </svg>
                            </span>
                        </button>
                    </form>
                </div>
            </div>

            <!-- Sağ: İletişim Bilgileri -->
            <div class="contact-info-col">
                <!-- E-posta Kartı -->
                <div class="contact-info-card glass-card">
                    <div class="contact-info-icon">📧</div>
                    <div class="contact-info-body">
                        <h3 class="contact-info-title">E-posta</h3>
                        <p class="contact-info-text"><%= typeof contactEmail !== 'undefined' ? contactEmail : 'info@paradoks.store' %></p>
                    </div>
                </div>

                <!-- Telefon Kartı -->
                <div class="contact-info-card glass-card">
                    <div class="contact-info-icon">📞</div>
                    <div class="contact-info-body">
                        <h3 class="contact-info-title">Telefon</h3>
                        <p class="contact-info-text"><%= typeof contactPhone !== 'undefined' ? contactPhone : '+90 (212) 555 00 00' %></p>
                    </div>
                </div>

                <!-- Adres Kartı -->
                <div class="contact-info-card glass-card">
                    <div class="contact-info-icon">📍</div>
                    <div class="contact-info-body">
                        <h3 class="contact-info-title">Adres</h3>
                        <p class="contact-info-text"><%= typeof contactAddress !== 'undefined' ? contactAddress : 'İstanbul, Türkiye' %></p>
                    </div>
                </div>

                <!-- Harita Placeholder -->
                <div class="contact-map-placeholder glass-card">
                    <div class="map-gradient">
                        <div class="map-pin">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                <circle cx="12" cy="10" r="3"/>
                            </svg>
                        </div>
                        <p class="map-text">Harita Görünümü</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
