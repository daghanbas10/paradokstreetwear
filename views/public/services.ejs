<!-- Skeleton Loading CSS + Kategori Filtre JS -->
<style>
/* Skeleton placeholder for images */
.service-detail-card img {
    background: linear-gradient(90deg, #f0ede8 25%, #e8e5e0 50%, #f0ede8 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s ease-in-out infinite;
    min-height: 200px;
    object-fit: cover;
}
.service-detail-card img[src] {
    min-height: auto;
}
@keyframes skeletonShimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}

/* CTA Button hover/active smooth transitions */
.service-detail-card .btn {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    position: relative;
    overflow: hidden;
}
.service-detail-card .btn:hover {
    background: #333 !important;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}
.service-detail-card .btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

/* Filter tab hover */
.cat-tab:hover {
    border-color: #1A1A1A !important;
    background: rgba(0,0,0,0.04) !important;
}
.cat-tab.active {
    background: #1A1A1A !important;
    color: #F5F2ED !important;
    border-color: #1A1A1A !important;
}

/* Category section transition */
.category-section {
    transition: opacity 0.4s ease, max-height 0.5s ease;
}
.category-section.hidden {
    display: none;
}
</style>

<script>
// Kategori Filtreleme
document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('.cat-tab');
    const sections = document.querySelectorAll('.category-section');
    
    tabs.forEach(tab => {
        tab.addEventListener('click', function() {
            const filter = this.dataset.filter;
            
            // Tab aktif durumu güncelle
            tabs.forEach(t => {
                t.classList.remove('active');
                t.style.background = 'transparent';
                t.style.color = '#1A1A1A';
                t.style.borderColor = 'rgba(0,0,0,0.15)';
            });
            this.classList.add('active');
            this.style.background = '#1A1A1A';
            this.style.color = '#F5F2ED';
            this.style.borderColor = '#1A1A1A';
            
            // Bölümleri göster/gizle
            sections.forEach(section => {
                if (filter === 'all' || section.dataset.category === filter) {
                    section.classList.remove('hidden');
                    section.style.opacity = '1';
                } else {
                    section.classList.add('hidden');
                    section.style.opacity = '0';
                }
            });
            
            // Smooth scroll yukarı
            window.scrollTo({ top: document.getElementById('categoryTabs').offsetTop - 100, behavior: 'smooth' });
        });
    });
});
</script>

