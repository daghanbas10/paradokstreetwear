<%- include('../partials/header') %>

<!-- Hero Section -->
<section class="hero">
    <!-- Animated Background Elements -->
    <div class="hero-bg-elements">
        <div class="gradient-orb gradient-orb-1"></div>
        <div class="gradient-orb gradient-orb-2"></div>
        <div class="gradient-orb gradient-orb-3"></div>
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>
        <div class="floating-shape shape-4"></div>
        <div class="floating-shape shape-5"></div>
    </div>
    <div class="hero-container">
        <div class="hero-content">
            <span class="section-tag" style="margin-bottom: 24px;">◾ NEW DROP • 2026 SUMMER</span>
            <h1 class="hero-title">
                <span class="hero-title-gradient"><%= typeof heroTitle !== 'undefined' ? heroTitle : 'Kuralları Sen Yaz' %></span>
            </h1>
            <p class="hero-subtitle"><%= typeof heroSubtitle !== 'undefined' ? heroSubtitle : 'Sıradan olmayı reddedenler için tasarlandı.' %></p>
            <div class="hero-buttons">
                <a href="/koleksiyon" class="btn btn-primary btn-lg">
                    <span>Koleksiyonu Keşfet</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="/iletisim" class="btn btn-outline">
                    <span>Bize Ulaş</span>
                </a>
            </div>
        </div>
        <!-- Hero Görsel -->
        <div class="hero-visual" style="margin-top: 48px; text-align: center;">
            <img src="/uploads/summer-hero.png" alt="PARADOKS Yaz 2026 Koleksiyonu" style="max-width: 700px; width: 100%; border-radius: 20px; box-shadow: 0 30px 80px rgba(0,0,0,0.1); animation: fadeInUp 1.2s ease-out 0.3s both;">
        </div>
    </div>
</section>

<!-- Koleksiyon Önizleme -->
<section class="services-preview section">
    <div class="container">
        <div class="section-header scroll-reveal">
            <span class="section-tag">Yaz 2026</span>
            <h2 class="section-title">Yaz Koleksiyonu</h2>
            <p class="section-description">Güneş, sokak ve stil. Bu yazın en sıcak parçaları seni bekliyor.</p>
        </div>
        <div class="services-grid">
            <!-- Erkek Giyim -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">👕</span>
                </div>
                <h3 class="service-card-title">Erkek Giyim</h3>
                <p class="service-card-desc">Oversize tişört, arkası baskılı tee, polo yaka ve yazlık setler. Sokak stilinin temelleri.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
            <!-- Kadın Giyim -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🌸</span>
                </div>
                <h3 class="service-card-title">Kadın Giyim</h3>
                <p class="service-card-desc">Crop top, baby tee, tenisçi eteği, kargo mini etek ve yırtmaçlı şort. Feminine sokak enerjisi.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
            <!-- Şort & Alt -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🩳</span>
                </div>
                <h3 class="service-card-title">Şort & Alt</h3>
                <p class="service-card-desc">Mesh şort, cargo şort, jorts ve bermuda. Quick-dry kumaşlar, İstanbul yazına özel.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
            <!-- Aksesuar -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🧢</span>
                </div>
                <h3 class="service-card-title">Aksesuar</h3>
                <p class="service-card-desc">Tote bag, trucker cap, sokak çorapları ve bucket hat. Tarzını tamamla.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
        </div>
    </div>
</section>



<!-- Hakkımızda Kısa -->
<section class="about-preview section">
    <div class="container">
        <div class="about-grid">
            <!-- Sol: Metin -->
            <div class="about-text-col scroll-reveal">
                <span class="section-tag">Hikayemiz</span>
                <h2 class="section-title">Tarzı Çelişkiyle Yaz</h2>
                <p class="about-text">
                    <%= typeof aboutText !== 'undefined' ? aboutText : 'PARADOKS, İstanbul\'un kalbinde doğdu. Adımız gibi tarzımız da çelişkilerden besleniyor — minimal ama cesur, rahat ama dikkat çekici.' %>
                </p>
                <img src="/uploads/about-brand.png" alt="PARADOKS Mağaza" style="width: 100%; border-radius: 16px; margin: 1.5rem 0; opacity: 0.9;">
                <a href="/iletisim" class="btn btn-primary">
                    <span>Bize Ulaşın</span>
                </a>
            </div>
            <!-- Sağ: İstatistik Kartları -->
            <div class="about-stats-col">
                <div class="stats-grid">
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="5000">0</span>
                        <span class="stat-suffix">+</span>
                        <p class="stat-label">Mutlu Müşteri</p>
                    </div>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="50">0</span>
                        <span class="stat-suffix">+</span>
                        <p class="stat-label">Ürün Çeşidi</p>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="100">0</span>
                        <span class="stat-suffix">%</span>
                        <p class="stat-label">Yerli Üretim</p>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="98">0</span>
                        <span class="stat-suffix">%</span>
                        <p class="stat-label">Memnuniyet</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Blog Önizleme -->
<section class="blog-preview section">
    <div class="container">
        <div class="section-header scroll-reveal">
            <span class="section-tag">Blogumuz</span>
            <h2 class="section-title">Son Yazılarımız</h2>
            <p class="section-description">Sektörel gelişmeler, ipuçları ve uzman görüşlerimizi keşfedin.</p>
        </div>
        <% if (typeof posts !== 'undefined' && posts && posts.length > 0) { %>
            <div class="blog-grid">
                <% posts.slice(0, 3).forEach(function(post) { %>
                    <article class="blog-card glass-card scroll-reveal">
                        <% if (post.cover_image) { %>
                            <div class="blog-card-image">
                                <img src="<%= post.cover_image %>" alt="<%= post.title %>" loading="lazy">
                            </div>
                        <% } else { %>
                            <div class="blog-card-image blog-card-image-placeholder">
                                <div class="placeholder-icon">📝</div>
                            </div>
                        <% } %>
                        <div class="blog-card-body">
                            <div class="blog-card-meta">
                                <span class="blog-card-date">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                        <line x1="16" y1="2" x2="16" y2="6"/>
                                        <line x1="8" y1="2" x2="8" y2="6"/>
                                        <line x1="3" y1="10" x2="21" y2="10"/>
                                    </svg>
                                    <%= post.created_at ? new Date(post.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) : '' %>
                                </span>
                            </div>
                            <h3 class="blog-card-title">
                                <a href="/blog/<%= post.slug %>"><%= post.title %></a>
                            </h3>
                            <p class="blog-card-excerpt"><%= post.excerpt || '' %></p>
                            <a href="/blog/<%= post.slug %>" class="blog-card-link">
                                Devamını Oku
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"/>
                                    <polyline points="12 5 19 12 12 19"/>
                                </svg>
                            </a>
                        </div>
                    </article>
                <% }); %>
            </div>
            <div class="section-footer">
                <a href="/blog" class="btn btn-outline">Tüm Yazıları Gör</a>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">📝</div>
                <p class="empty-state-text">Henüz blog yazısı bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</section>

<section class="cta-section">
    <div class="cta-bg-elements">
        <div class="cta-gradient-orb cta-orb-1"></div>
        <div class="cta-gradient-orb cta-orb-2"></div>
    </div>
    <div class="container">
        <div class="cta-content scroll-reveal">
            <h2 class="cta-title">Tarzını Bul, Kuralları Yık</h2>
            <p class="cta-text">
                Yeni drop'lardan ilk sen haberdar ol. Özel indirimler, 
                limitli ürünler ve erken erişim fırsatları seni bekliyor.
            </p>
            <div class="hero-buttons" style="justify-content: center;">
                <a href="/koleksiyon" class="btn btn-primary btn-lg">
                    <span>Koleksiyonu Keşfet</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="/iletisim" class="btn btn-outline">
                    <span>Bize Ulaş</span>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Kayan Marka Bandı -->
<section class="marquee-section" style="padding: 20px 0; overflow: hidden; background: linear-gradient(135deg, rgba(163,177,138,0.1), rgba(212,163,115,0.06)); border-top: 1px solid rgba(0,0,0,0.06); border-bottom: 1px solid rgba(0,0,0,0.06);">
    <div class="marquee-track" style="display: flex; animation: marqueeScroll 25s linear infinite; white-space: nowrap;">
        <span class="marquee-item" style="display: inline-flex; align-items: center; gap: 32px; padding: 0 32px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 3px; color: rgba(26,26,26,0.35);">
            ☀️ YAZ 2026 &nbsp;&nbsp; ★ OVERSIZE TİŞÖRT &nbsp;&nbsp; ★ CROP TOP &nbsp;&nbsp; ★ MESH ŞORT &nbsp;&nbsp; ★ ÜCRETSİZ KARGO &nbsp;&nbsp; ★ LİMİTED DROP &nbsp;&nbsp; ★ SOKAK STİLİ &nbsp;&nbsp; ★ PREMİUM KALİTE &nbsp;&nbsp;
        </span>
        <span class="marquee-item" style="display: inline-flex; align-items: center; gap: 32px; padding: 0 32px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 3px; color: rgba(26,26,26,0.35);">
            ☀️ YAZ 2026 &nbsp;&nbsp; ★ OVERSIZE TİŞÖRT &nbsp;&nbsp; ★ CROP TOP &nbsp;&nbsp; ★ MESH ŞORT &nbsp;&nbsp; ★ ÜCRETSİZ KARGO &nbsp;&nbsp; ★ LİMİTED DROP &nbsp;&nbsp; ★ SOKAK STİLİ &nbsp;&nbsp; ★ PREMİUM KALİTE &nbsp;&nbsp;
        </span>
    </div>
</section>

<!-- Üyelik Formu -->
<section class="section" style="padding: 80px 0;">
    <div class="container">
        <div class="glass-card scroll-reveal" style="padding: 60px 48px; max-width: 560px; margin: 0 auto; background: rgba(163,177,138,0.06); border: 1px solid rgba(0,0,0,0.08);">

            <div style="text-align: center; margin-bottom: 36px;">
                <span class="section-tag">🔐 ÜYELİK</span>
                <h2 style="font-family: 'Outfit', sans-serif; font-size: clamp(1.4rem, 3vw, 1.8rem); font-weight: 700; color: #1A1A1A; margin: 16px 0 8px;">PARADOKS Ailesine Katıl</h2>
                <p style="color: #6B6B6B; font-size: 0.9rem; line-height: 1.7;">Yeni drop'lar, özel kampanyalar ve early access fırsatlarından ilk sen haberdar ol.</p>
            </div>

            <form id="membership-form">

                <!-- Ad Soyad -->
                <div style="margin-bottom: 16px;">
                    <label style="display:block; font-size:0.78rem; font-weight:600; color:#1A1A1A; margin-bottom:6px; letter-spacing:0.5px;">AD SOYAD</label>
                    <input type="text" name="name" placeholder="Adın ve soyadın" required minlength="2" maxlength="100" style="width:100%; padding:14px 18px; border-radius:12px; border:1px solid rgba(0,0,0,0.1); background:#FFFFFE; color:#1A1A1A; font-family:'Inter',sans-serif; font-size:0.9rem; outline:none; transition:all 0.3s ease; box-sizing:border-box;">
                </div>

                <!-- E-posta -->
                <div style="margin-bottom: 16px;">
                    <label style="display:block; font-size:0.78rem; font-weight:600; color:#1A1A1A; margin-bottom:6px; letter-spacing:0.5px;">E-POSTA</label>
                    <input type="email" name="email" placeholder="ornek@email.com" required style="width:100%; padding:14px 18px; border-radius:12px; border:1px solid rgba(0,0,0,0.1); background:#FFFFFE; color:#1A1A1A; font-family:'Inter',sans-serif; font-size:0.9rem; outline:none; transition:all 0.3s ease; box-sizing:border-box;">
                </div>

                <!-- Telefon -->
                <div style="margin-bottom: 16px;">
                    <label style="display:block; font-size:0.78rem; font-weight:600; color:#1A1A1A; margin-bottom:6px; letter-spacing:0.5px;">TELEFON <span style="color:#999; font-weight:400;">(opsiyonel)</span></label>
                    <input type="tel" name="phone" placeholder="05XX XXX XX XX" style="width:100%; padding:14px 18px; border-radius:12px; border:1px solid rgba(0,0,0,0.1); background:#FFFFFE; color:#1A1A1A; font-family:'Inter',sans-serif; font-size:0.9rem; outline:none; transition:all 0.3s ease; box-sizing:border-box;">
                </div>

                <!-- Cinsiyet + Beden — iki sütun -->
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:20px;">
                    <div>
                        <label style="display:block; font-size:0.78rem; font-weight:600; color:#1A1A1A; margin-bottom:6px; letter-spacing:0.5px;">İLGİLENDİĞİN KATEGORİ</label>
                        <select name="category" style="width:100%; padding:14px 18px; border-radius:12px; border:1px solid rgba(0,0,0,0.1); background:#FFFFFE; color:#1A1A1A; font-family:'Inter',sans-serif; font-size:0.9rem; outline:none; cursor:pointer; appearance:none; -webkit-appearance:none; background-image:url('data:image/svg+xml;utf8,<svg fill=\"%231A1A1A\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M7 10l5 5 5-5z\"/></svg>'); background-repeat:no-repeat; background-position:right 14px center; background-size:18px; box-sizing:border-box;">
                            <option value="">Seçiniz</option>
                            <option value="erkek">👔 Erkek Giyim</option>
                            <option value="kadin">🌸 Kadın Giyim</option>
                            <option value="hepsi">🔥 Hepsi</option>
                        </select>
                    </div>
                    <div>
                        <label style="display:block; font-size:0.78rem; font-weight:600; color:#1A1A1A; margin-bottom:6px; letter-spacing:0.5px;">BEDEN</label>
                        <select name="size" style="width:100%; padding:14px 18px; border-radius:12px; border:1px solid rgba(0,0,0,0.1); background:#FFFFFE; color:#1A1A1A; font-family:'Inter',sans-serif; font-size:0.9rem; outline:none; cursor:pointer; appearance:none; -webkit-appearance:none; background-image:url('data:image/svg+xml;utf8,<svg fill=\"%231A1A1A\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M7 10l5 5 5-5z\"/></svg>'); background-repeat:no-repeat; background-position:right 14px center; background-size:18px; box-sizing:border-box;">
                            <option value="">Seçiniz</option>
                            <option value="xs">XS</option>
                            <option value="s">S</option>
                            <option value="m">M</option>
                            <option value="l">L</option>
                            <option value="xl">XL</option>
                            <option value="xxl">XXL</option>
                        </select>
                    </div>
                </div>

                <!-- KVKK Onay -->
                <label for="kvkk" style="display:flex; align-items:flex-start; gap:10px; cursor:pointer; text-align:left; margin-bottom:8px;">
                    <input type="checkbox" id="kvkk" style="margin-top:3px; width:18px; height:18px; accent-color:#1A1A1A; flex-shrink:0; cursor:pointer;">
                    <span style="color:#6B6B6B; font-size:0.7rem; line-height:1.6;">
                        <strong style="color:#1A1A1A;">KVKK Aydınlatma Metni</strong>'ni okudum, anladım. Kişisel verilerimin PARADOKS tarafından yalnızca kampanya, yeni koleksiyon ve bilgilendirme amaçlı işlenmesine 6698 sayılı KVKK kapsamında onay veriyorum.
                    </span>
                </label>
                <p class="kvkk-warn" style="display:none; color:#c0392b; font-size:0.75rem; margin:4px 0 12px;">⚠ Devam etmek için KVKK onayını vermeniz gerekmektedir.</p>

                <!-- Hata mesajı -->
                <p id="form-error" style="display:none; color:#c0392b; font-size:0.8rem; margin:8px 0; padding:10px 14px; background:rgba(192,57,43,0.06); border-radius:8px; text-align:center;"></p>

                <!-- Kayıt Ol Butonu -->
                <button type="submit" id="submit-btn" class="btn btn-primary" style="width:100%; padding:16px; min-height:52px; font-size:0.95rem; font-weight:700; letter-spacing:1px; margin-top:8px; transition:all 0.3s ease; position:relative;">
                    <span id="btn-text">Üye Ol 🚀</span>
                    <span id="btn-spinner" style="display:none; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);">
                        <svg width="22" height="22" viewBox="0 0 24 24" style="animation: spin 0.8s linear infinite;"><circle cx="12" cy="12" r="10" stroke="#F5F2ED" stroke-width="3" fill="none" stroke-dasharray="31.4 31.4" stroke-linecap="round"/></svg>
                    </span>
                </button>
            </form>

            <script>
            document.getElementById('membership-form').addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const kvkk = document.getElementById('kvkk');
                const warn = document.querySelector('.kvkk-warn');
                const errorEl = document.getElementById('form-error');
                const btn = document.getElementById('submit-btn');
                const btnText = document.getElementById('btn-text');
                const btnSpinner = document.getElementById('btn-spinner');

                // KVKK kontrolü
                if (!kvkk.checked) { warn.style.display = 'block'; return; }
                warn.style.display = 'none';
                errorEl.style.display = 'none';

                // Double-submit koruması — buton kilitle + spinner
                btn.disabled = true;
                btn.style.opacity = '0.6';
                btn.style.pointerEvents = 'none';
                btnText.style.visibility = 'hidden';
                btnSpinner.style.display = 'inline';

                const formData = {
                    name: this.querySelector('[name=name]').value,
                    email: this.querySelector('[name=email]').value,
                    phone: this.querySelector('[name=phone]').value,
                    category: this.querySelector('[name=category]').value,
                    size: this.querySelector('[name=size]').value
                };

                try {
                    const res = await fetch('/api/register', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    });
                    const data = await res.json();

                    if (res.ok && data.success) {
                        // Başarı — form gizle, başarı mesajı göster
                        this.style.display = 'none';
                        document.getElementById('form-success').style.display = 'flex';
                    } else {
                        // Hata mesajı göster
                        errorEl.textContent = data.error || 'Bir hata oluştu.';
                        errorEl.style.display = 'block';
                        // Butonu geri aç
                        btn.disabled = false;
                        btn.style.opacity = '1';
                        btn.style.pointerEvents = 'auto';
                        btnText.style.visibility = 'visible';
                        btnSpinner.style.display = 'none';
                    }
                } catch (err) {
                    errorEl.textContent = 'Bağlantı hatası. Lütfen tekrar deneyin.';
                    errorEl.style.display = 'block';
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    btn.style.pointerEvents = 'auto';
                    btnText.style.visibility = 'visible';
                    btnSpinner.style.display = 'none';
                }
            });
            </script>

            <!-- Başarı Mesajı -->
            <div id="form-success" style="display:none; flex-direction:column; align-items:center; text-align:center; padding:20px 0;">
                <div style="width:64px; height:64px; border-radius:50%; background:#A3B18A; display:flex; align-items:center; justify-content:center; margin-bottom:20px;">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <h3 style="font-family:'Outfit',sans-serif; font-size:1.3rem; font-weight:700; color:#1A1A1A; margin-bottom:8px;">Hoş Geldin! 🎉</h3>
                <p style="color:#6B6B6B; font-size:0.9rem; line-height:1.6;">PARADOKS ailesine başarıyla katıldın.<br>2027'de sokakta buluşuyoruz!</p>
            </div>

            <p style="color:rgba(0,0,0,0.2); font-size:0.68rem; margin-top:16px; text-align:center;">Dilediğin zaman üyeliğini iptal edebilirsin. Gizliliğine saygı duyuyoruz.</p>
        </div>
    </div>
</section>

<style>
@keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
#membership-form input:focus,
#membership-form select:focus {
    border-color: #A3B18A;
    box-shadow: 0 0 20px rgba(163,177,138,0.15);
}
#membership-form input::placeholder {
    color: #B0B0B0;
}
@keyframes spin {
    0% { transform: translate(-50%,-50%) rotate(0deg); }
    100% { transform: translate(-50%,-50%) rotate(360deg); }
}
</style>

<%- include('../partials/footer') %>

