<%- include('../partials/header') %>

<!-- Hero Section -->
<section class="hero">
    <!-- Animated Background Elements -->
    <div class="hero-bg-elements">
        <div class="gradient-orb gradient-orb-1"></div>
        <div class="gradient-orb gradient-orb-2"></div>
        <div class="gradient-orb gradient-orb-3"></div>
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>
        <div class="floating-shape shape-4"></div>
        <div class="floating-shape shape-5"></div>
    </div>
    <div class="hero-container">
        <div class="hero-content">
            <span class="section-tag" style="margin-bottom: 24px;">◾ NEW DROP • 2026 SUMMER</span>
            <h1 class="hero-title">
                <span class="hero-title-gradient"><%= typeof heroTitle !== 'undefined' ? heroTitle : 'Kuralları Sen Yaz' %></span>
            </h1>
            <p class="hero-subtitle"><%= typeof heroSubtitle !== 'undefined' ? heroSubtitle : 'Sıradan olmayı reddedenler için tasarlandı.' %></p>
            <div class="hero-buttons">
                <a href="/koleksiyon" class="btn btn-primary btn-lg">
                    <span>Koleksiyonu Keşfet</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="/iletisim" class="btn btn-outline">
                    <span>Bize Ulaş</span>
                </a>
            </div>
        </div>
        <!-- Hero Görsel -->
        <div class="hero-visual" style="margin-top: 48px; text-align: center;">
            <img src="/uploads/summer-hero.png" alt="PARADOKS Yaz 2026 Koleksiyonu" style="max-width: 700px; width: 100%; border-radius: 20px; box-shadow: 0 30px 80px rgba(0,0,0,0.1); animation: fadeInUp 1.2s ease-out 0.3s both;">
        </div>
    </div>
</section>

<!-- Koleksiyon Önizleme -->
<section class="services-preview section">
    <div class="container">
        <div class="section-header scroll-reveal">
            <span class="section-tag">Yaz 2026</span>
            <h2 class="section-title">Yaz Koleksiyonu</h2>
            <p class="section-description">Güneş, sokak ve stil. Bu yazın en sıcak parçaları seni bekliyor.</p>
        </div>
        <div class="services-grid">
            <!-- Erkek Giyim -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">👕</span>
                </div>
                <h3 class="service-card-title">Erkek Giyim</h3>
                <p class="service-card-desc">Oversize tişört, arkası baskılı tee, polo yaka ve yazlık setler. Sokak stilinin temelleri.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
            <!-- Kadın Giyim -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🌸</span>
                </div>
                <h3 class="service-card-title">Kadın Giyim</h3>
                <p class="service-card-desc">Crop top, baby tee, tenisçi eteği, kargo mini etek ve yırtmaçlı şort. Feminine sokak enerjisi.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
            <!-- Şort & Alt -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🩳</span>
                </div>
                <h3 class="service-card-title">Şort & Alt</h3>
                <p class="service-card-desc">Mesh şort, cargo şort, jorts ve bermuda. Quick-dry kumaşlar, İstanbul yazına özel.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
            <!-- Aksesuar -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🧢</span>
                </div>
                <h3 class="service-card-title">Aksesuar</h3>
                <p class="service-card-desc">Tote bag, trucker cap, sokak çorapları ve bucket hat. Tarzını tamamla.</p>
                <a href="/koleksiyon" class="service-card-link">
                    Keşfet →
                </a>
            </div>
        </div>
    </div>
</section>



<!-- Hakkımızda Kısa -->
<section class="about-preview section">
    <div class="container">
        <div class="about-grid">
            <!-- Sol: Metin -->
            <div class="about-text-col scroll-reveal">
                <span class="section-tag">Hikayemiz</span>
                <h2 class="section-title">Tarzı Çelişkiyle Yaz</h2>
                <p class="about-text">
                    <%= typeof aboutText !== 'undefined' ? aboutText : 'PARADOKS, İstanbul\'un kalbinde doğdu. Adımız gibi tarzımız da çelişkilerden besleniyor — minimal ama cesur, rahat ama dikkat çekici.' %>
                </p>
                <img src="/uploads/about-brand.png" alt="PARADOKS Mağaza" style="width: 100%; border-radius: 16px; margin: 1.5rem 0; opacity: 0.9;">
                <a href="/iletisim" class="btn btn-primary">
                    <span>Bize Ulaşın</span>
                </a>
            </div>
            <!-- Sağ: İstatistik Kartları -->
            <div class="about-stats-col">
                <div class="stats-grid">
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="5000">0</span>
                        <span class="stat-suffix">+</span>
                        <p class="stat-label">Mutlu Müşteri</p>
                    </div>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="50">0</span>
                        <span class="stat-suffix">+</span>
                        <p class="stat-label">Ürün Çeşidi</p>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="100">0</span>
                        <span class="stat-suffix">%</span>
                        <p class="stat-label">Yerli Üretim</p>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="98">0</span>
                        <span class="stat-suffix">%</span>
                        <p class="stat-label">Memnuniyet</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Blog Önizleme -->
<section class="blog-preview section">
    <div class="container">
        <div class="section-header scroll-reveal">
            <span class="section-tag">Blogumuz</span>
            <h2 class="section-title">Son Yazılarımız</h2>
            <p class="section-description">Sektörel gelişmeler, ipuçları ve uzman görüşlerimizi keşfedin.</p>
        </div>
        <% if (typeof posts !== 'undefined' && posts && posts.length > 0) { %>
            <div class="blog-grid">
                <% posts.slice(0, 3).forEach(function(post) { %>
                    <article class="blog-card glass-card scroll-reveal">
                        <% if (post.cover_image) { %>
                            <div class="blog-card-image">
                                <img src="<%= post.cover_image %>" alt="<%= post.title %>" loading="lazy">
                            </div>
                        <% } else { %>
                            <div class="blog-card-image blog-card-image-placeholder">
                                <div class="placeholder-icon">📝</div>
                            </div>
                        <% } %>
                        <div class="blog-card-body">
                            <div class="blog-card-meta">
                                <span class="blog-card-date">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                        <line x1="16" y1="2" x2="16" y2="6"/>
                                        <line x1="8" y1="2" x2="8" y2="6"/>
                                        <line x1="3" y1="10" x2="21" y2="10"/>
                                    </svg>
                                    <%= post.created_at ? new Date(post.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) : '' %>
                                </span>
                            </div>
                            <h3 class="blog-card-title">
                                <a href="/blog/<%= post.slug %>"><%= post.title %></a>
                            </h3>
                            <p class="blog-card-excerpt"><%= post.excerpt || '' %></p>
                            <a href="/blog/<%= post.slug %>" class="blog-card-link">
                                Devamını Oku
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"/>
                                    <polyline points="12 5 19 12 12 19"/>
                                </svg>
                            </a>
                        </div>
                    </article>
                <% }); %>
            </div>
            <div class="section-footer">
                <a href="/blog" class="btn btn-outline">Tüm Yazıları Gör</a>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">📝</div>
                <p class="empty-state-text">Henüz blog yazısı bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</section>

<section class="cta-section">
    <div class="cta-bg-elements">
        <div class="cta-gradient-orb cta-orb-1"></div>
        <div class="cta-gradient-orb cta-orb-2"></div>
    </div>
    <div class="container">
        <div class="cta-content scroll-reveal">
            <h2 class="cta-title">Tarzını Bul, Kuralları Yık</h2>
            <p class="cta-text">
                Yeni drop'lardan ilk sen haberdar ol. Özel indirimler, 
                limitli ürünler ve erken erişim fırsatları seni bekliyor.
            </p>
            <div class="hero-buttons" style="justify-content: center;">
                <a href="/koleksiyon" class="btn btn-primary btn-lg">
                    <span>Koleksiyonu Keşfet</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="/iletisim" class="btn btn-outline">
                    <span>Bize Ulaş</span>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Kayan Marka Bandı -->
<section class="marquee-section" style="padding: 20px 0; overflow: hidden; background: linear-gradient(135deg, rgba(163,177,138,0.1), rgba(212,163,115,0.06)); border-top: 1px solid rgba(0,0,0,0.06); border-bottom: 1px solid rgba(0,0,0,0.06);">
    <div class="marquee-track" style="display: flex; animation: marqueeScroll 25s linear infinite; white-space: nowrap;">
        <span class="marquee-item" style="display: inline-flex; align-items: center; gap: 32px; padding: 0 32px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 3px; color: rgba(26,26,26,0.35);">
            ☀️ YAZ 2026 &nbsp;&nbsp; ★ OVERSIZE TİŞÖRT &nbsp;&nbsp; ★ CROP TOP &nbsp;&nbsp; ★ MESH ŞORT &nbsp;&nbsp; ★ ÜCRETSİZ KARGO &nbsp;&nbsp; ★ LİMİTED DROP &nbsp;&nbsp; ★ SOKAK STİLİ &nbsp;&nbsp; ★ PREMİUM KALİTE &nbsp;&nbsp;
        </span>
        <span class="marquee-item" style="display: inline-flex; align-items: center; gap: 32px; padding: 0 32px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 3px; color: rgba(26,26,26,0.35);">
            ☀️ YAZ 2026 &nbsp;&nbsp; ★ OVERSIZE TİŞÖRT &nbsp;&nbsp; ★ CROP TOP &nbsp;&nbsp; ★ MESH ŞORT &nbsp;&nbsp; ★ ÜCRETSİZ KARGO &nbsp;&nbsp; ★ LİMİTED DROP &nbsp;&nbsp; ★ SOKAK STİLİ &nbsp;&nbsp; ★ PREMİUM KALİTE &nbsp;&nbsp;
        </span>
    </div>
</section>

<!-- Newsletter Kayıt -->
<section class="section" style="padding: 80px 0;">
    <div class="container">
        <div class="glass-card scroll-reveal" style="padding: 60px 48px; text-align: center; max-width: 700px; margin: 0 auto; background: rgba(163,177,138,0.08); border: 1px solid rgba(0,0,0,0.08);">

            <span class="section-tag">📬 NEWSLETTER</span>
            <h2 style="font-family: 'Outfit', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #1A1A1A; margin: 16px 0 12px;">Drop'ları Kaçırma</h2>
            <p style="color: #6B6B6B; font-size: 1rem; line-height: 1.8; margin-bottom: 28px;">Yeni koleksiyonlar, limited drop'lar ve özel indirimlerden ilk sen haberdar ol. Spam yok, sadece stil.</p>
            <form id="newsletter-form" style="display: flex; gap: 12px; max-width: 480px; margin: 0 auto; flex-wrap: wrap; justify-content: center;" onsubmit="event.preventDefault(); if(!this.querySelector('#kvkk').checked){this.querySelector('.kvkk-warn').style.display='block';return;} this.querySelector('.kvkk-warn').style.display='none'; this.querySelector('button').textContent='✓ Kayıt Olundu!'; this.querySelector('button').style.background='#A3B18A'; this.querySelector('input[type=email]').value='';">
                <input type="email" placeholder="E-posta adresin" required style="flex: 1; min-width: 240px; padding: 14px 20px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.1); background: #FFFFFE; color: #1A1A1A; font-family: 'Inter', sans-serif; font-size: 0.95rem; outline: none; transition: border-color 0.3s;">
                <button type="submit" class="btn btn-primary" style="padding: 14px 28px; white-space: nowrap;">Abone Ol 🔔</button>
            </form>
            <!-- KVKK Onay -->
            <label for="kvkk" style="display: flex; align-items: flex-start; gap: 10px; max-width: 480px; margin: 20px auto 0; cursor: pointer; text-align: left;">
                <input type="checkbox" id="kvkk" style="margin-top: 3px; width: 18px; height: 18px; accent-color: #1A1A1A; flex-shrink: 0; cursor: pointer;">
                <span style="color: #6B6B6B; font-size: 0.72rem; line-height: 1.6;">
                    <strong style="color: #1A1A1A;">KVKK Aydınlatma Metni</strong>'ni okudum, anladım. Kişisel verilerimin PARADOKS tarafından yalnızca kampanya, yeni koleksiyon ve bilgilendirme amaçlı e-posta gönderimi için 6698 sayılı KVKK kapsamında işlenmesine onay veriyorum.
                </span>
            </label>
            <p class="kvkk-warn" style="display:none; color:#c0392b; font-size:0.75rem; margin-top:8px;">⚠ Devam etmek için KVKK onayını vermeniz gerekmektedir.</p>
            <p style="color: rgba(0,0,0,0.25); font-size: 0.7rem; margin-top: 12px;">Dilediğin zaman çıkabilirsin. Gizliliğine saygı duyuyoruz.</p>
        </div>
    </div>
</section>

<style>
@keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
#newsletter-form input:focus {
    border-color: #A3B18A;
    box-shadow: 0 0 20px rgba(163,177,138,0.2);
}
</style>

<%- include('../partials/footer') %>

