<%- include('../partials/header') %>

<!-- Hero Section -->
<section class="hero">
    <!-- Animated Background Elements -->
    <div class="hero-bg-elements">
        <div class="gradient-orb gradient-orb-1"></div>
        <div class="gradient-orb gradient-orb-2"></div>
        <div class="gradient-orb gradient-orb-3"></div>
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>
        <div class="floating-shape shape-4"></div>
        <div class="floating-shape shape-5"></div>
    </div>
    <div class="hero-container">
        <div class="hero-content">
            <span class="section-tag" style="margin-bottom: 24px;">◾ NEW DROP • 2026 SUMMER</span>
            <h1 class="hero-title">
                <span class="hero-title-gradient"><%= typeof heroTitle !== 'undefined' ? heroTitle : 'Kuralları Sen Yaz' %></span>
            </h1>
            <p class="hero-subtitle"><%= typeof heroSubtitle !== 'undefined' ? heroSubtitle : 'Sıradan olmayı reddedenler için tasarlandı.' %></p>
            <div class="hero-buttons">
                <a href="/hizmetler" class="btn btn-primary btn-lg">
                    <span>Koleksiyonu Keşfet</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="/iletisim" class="btn btn-outline">
                    <span>Bize Ulaş</span>
                </a>
            </div>
        </div>
        <!-- Hero Görsel -->
        <div class="hero-visual" style="margin-top: 48px; text-align: center;">
            <img src="/uploads/hero-streetwear.png" alt="PARADOKS Streetwear Koleksiyon" style="max-width: 700px; width: 100%; border-radius: 20px; box-shadow: 0 30px 80px rgba(139,92,246,0.15); animation: fadeInUp 1.2s ease-out 0.3s both;">
        </div>
    </div>
</section>

<!-- Koleksiyon Önizleme -->
<section class="services-preview section">
    <div class="container">
        <div class="section-header scroll-reveal">
            <span class="section-tag">Koleksiyon</span>
            <h2 class="section-title">Kategoriler</h2>
            <p class="section-description">Sokak stilinin olmazsa olmazları. Her parça, kaliteli kumaş ve özenli üretimle hayat buluyor.</p>
        </div>
        <div class="services-grid">
            <!-- Tişört -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">👕</span>
                </div>
                <h3 class="service-card-title">Oversize Tişörtler</h3>
                <p class="service-card-desc">300gsm premium pamuktan üretilen, pre-shrunk teknolojili oversize tişörtler. Cesur grafikler ve minimal tasarımlar bir arada.</p>
                <a href="/hizmetler" class="service-card-link">
                    Koleksiyonu Keşfet
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
            </div>
            <!-- Hoodie -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🧥</span>
                </div>
                <h3 class="service-card-title">Hoodie & Sweatshirt</h3>
                <p class="service-card-desc">400gsm heavyweight hoodie'ler. Boxy fit kesim, kanguru cep ve premium fermuarlı modeller. Dört mevsim vazgeçilmezin.</p>
                <a href="/hizmetler" class="service-card-link">
                    Koleksiyonu Keşfet
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
            </div>
            <!-- Şort -->
            <div class="service-card glass-card scroll-reveal">
                <div class="service-icon">
                    <span class="service-emoji">🩳</span>
                </div>
                <h3 class="service-card-title">Şort & Bermuda</h3>
                <p class="service-card-desc">Cargo, mesh ve sweat modelleri. Nefes alan kumaşlar ve dayanıklı dikişlerle İstanbul yazına özel tasarlandı.</p>
                <a href="/hizmetler" class="service-card-link">
                    Koleksiyonu Keşfet
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>



<!-- Hakkımızda Kısa -->
<section class="about-preview section">
    <div class="container">
        <div class="about-grid">
            <!-- Sol: Metin -->
            <div class="about-text-col scroll-reveal">
                <span class="section-tag">Hikayemiz</span>
                <h2 class="section-title">Tarzı Çelişkiyle Yaz</h2>
                <p class="about-text">
                    <%= typeof aboutText !== 'undefined' ? aboutText : 'PARADOKS, İstanbul\'un kalbinde doğdu. Adımız gibi tarzımız da çelişkilerden besleniyor — minimal ama cesur, rahat ama dikkat çekici.' %>
                </p>
                <img src="/uploads/about-brand.png" alt="PARADOKS Mağaza" style="width: 100%; border-radius: 16px; margin: 1.5rem 0; opacity: 0.9;">
                <a href="/iletisim" class="btn btn-primary">
                    <span>Bize Ulaşın</span>
                </a>
            </div>
            <!-- Sağ: İstatistik Kartları -->
            <div class="about-stats-col">
                <div class="stats-grid">
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="5000">0</span>
                        <span class="stat-suffix">+</span>
                        <p class="stat-label">Mutlu Müşteri</p>
                    </div>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="50">0</span>
                        <span class="stat-suffix">+</span>
                        <p class="stat-label">Ürün Çeşidi</p>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="100">0</span>
                        <span class="stat-suffix">%</span>
                        <p class="stat-label">Yerli Üretim</p>
                    </div>
                    <div class="stat-card glass-card scroll-reveal">
                        <span class="stat-number" data-target="98">0</span>
                        <span class="stat-suffix">%</span>
                        <p class="stat-label">Memnuniyet</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Blog Önizleme -->
<section class="blog-preview section">
    <div class="container">
        <div class="section-header scroll-reveal">
            <span class="section-tag">Blogumuz</span>
            <h2 class="section-title">Son Yazılarımız</h2>
            <p class="section-description">Sektörel gelişmeler, ipuçları ve uzman görüşlerimizi keşfedin.</p>
        </div>
        <% if (typeof posts !== 'undefined' && posts && posts.length > 0) { %>
            <div class="blog-grid">
                <% posts.slice(0, 3).forEach(function(post) { %>
                    <article class="blog-card glass-card scroll-reveal">
                        <% if (post.cover_image) { %>
                            <div class="blog-card-image">
                                <img src="<%= post.cover_image %>" alt="<%= post.title %>" loading="lazy">
                            </div>
                        <% } else { %>
                            <div class="blog-card-image blog-card-image-placeholder">
                                <div class="placeholder-icon">📝</div>
                            </div>
                        <% } %>
                        <div class="blog-card-body">
                            <div class="blog-card-meta">
                                <span class="blog-card-date">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                        <line x1="16" y1="2" x2="16" y2="6"/>
                                        <line x1="8" y1="2" x2="8" y2="6"/>
                                        <line x1="3" y1="10" x2="21" y2="10"/>
                                    </svg>
                                    <%= post.created_at ? new Date(post.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) : '' %>
                                </span>
                            </div>
                            <h3 class="blog-card-title">
                                <a href="/blog/<%= post.slug %>"><%= post.title %></a>
                            </h3>
                            <p class="blog-card-excerpt"><%= post.excerpt || '' %></p>
                            <a href="/blog/<%= post.slug %>" class="blog-card-link">
                                Devamını Oku
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"/>
                                    <polyline points="12 5 19 12 12 19"/>
                                </svg>
                            </a>
                        </div>
                    </article>
                <% }); %>
            </div>
            <div class="section-footer">
                <a href="/blog" class="btn btn-outline">Tüm Yazıları Gör</a>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">📝</div>
                <p class="empty-state-text">Henüz blog yazısı bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</section>

<section class="cta-section">
    <div class="cta-bg-elements">
        <div class="cta-gradient-orb cta-orb-1"></div>
        <div class="cta-gradient-orb cta-orb-2"></div>
    </div>
    <div class="container">
        <div class="cta-content scroll-reveal">
            <h2 class="cta-title">Tarzını Bul, Kuralları Yık</h2>
            <p class="cta-text">
                Yeni drop'lardan ilk sen haberdar ol. Özel indirimler, 
                limitli ürünler ve erken erişim fırsatları seni bekliyor.
            </p>
            <div class="hero-buttons" style="justify-content: center;">
                <a href="/hizmetler" class="btn btn-primary btn-lg">
                    <span>Koleksiyonu Keşfet</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="/iletisim" class="btn btn-outline">
                    <span>Bize Ulaş</span>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Kayan Marka Bandı -->
<section class="marquee-section" style="padding: 20px 0; overflow: hidden; background: linear-gradient(135deg, rgba(108,99,255,0.08), rgba(139,92,246,0.05)); border-top: 1px solid rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.04);">
    <div class="marquee-track" style="display: flex; animation: marqueeScroll 25s linear infinite; white-space: nowrap;">
        <span class="marquee-item" style="display: inline-flex; align-items: center; gap: 32px; padding: 0 32px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 3px; color: rgba(255,255,255,0.5);">
            ★ PARADOKS STREETWEAR &nbsp;&nbsp; ★ OVERSIZE TİŞÖRT &nbsp;&nbsp; ★ HOODİE KOLEKSİYONU &nbsp;&nbsp; ★ LİMİTED EDİTİON &nbsp;&nbsp; ★ ÜCRETSİZ KARGO &nbsp;&nbsp; ★ YENİ SEZON 2026 &nbsp;&nbsp; ★ SOKAK STİLİ &nbsp;&nbsp; ★ PREMİUM KALİTE &nbsp;&nbsp;
        </span>
        <span class="marquee-item" style="display: inline-flex; align-items: center; gap: 32px; padding: 0 32px; font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 3px; color: rgba(255,255,255,0.5);">
            ★ PARADOKS STREETWEAR &nbsp;&nbsp; ★ OVERSIZE TİŞÖRT &nbsp;&nbsp; ★ HOODİE KOLEKSİYONU &nbsp;&nbsp; ★ LİMİTED EDİTİON &nbsp;&nbsp; ★ ÜCRETSİZ KARGO &nbsp;&nbsp; ★ YENİ SEZON 2026 &nbsp;&nbsp; ★ SOKAK STİLİ &nbsp;&nbsp; ★ PREMİUM KALİTE &nbsp;&nbsp;
        </span>
    </div>
</section>

<!-- Newsletter Kayıt -->
<section class="section" style="padding: 80px 0;">
    <div class="container">
        <div class="glass-card scroll-reveal" style="padding: 60px 48px; text-align: center; max-width: 700px; margin: 0 auto; background: linear-gradient(135deg, rgba(108,99,255,0.06), rgba(139,92,246,0.03)); border: 1px solid rgba(108,99,255,0.15);">
            <span class="section-tag">📬 NEWSLETTER</span>
            <h2 style="font-family: 'Outfit', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #FFFFFE; margin: 16px 0 12px;">Drop'ları Kaçırma</h2>
            <p style="color: #8B8CA0; font-size: 1rem; line-height: 1.8; margin-bottom: 28px;">Yeni koleksiyonlar, limited drop'lar ve özel indirimlerden ilk sen haberdar ol. Spam yok, sadece stil.</p>
            <form id="newsletter-form" style="display: flex; gap: 12px; max-width: 480px; margin: 0 auto; flex-wrap: wrap; justify-content: center;" onsubmit="event.preventDefault(); this.querySelector('button').textContent='✓ Kayıt Olundu!'; this.querySelector('button').style.background='linear-gradient(135deg, #00E676, #00C853)'; this.querySelector('input').value='';">
                <input type="email" placeholder="E-posta adresin" required style="flex: 1; min-width: 240px; padding: 14px 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.04); color: #FFFFFE; font-family: 'Inter', sans-serif; font-size: 0.95rem; outline: none; transition: border-color 0.3s;">
                <button type="submit" class="btn btn-primary" style="padding: 14px 28px; white-space: nowrap;">Abone Ol 🔔</button>
            </form>
            <p style="color: rgba(255,255,255,0.25); font-size: 0.75rem; margin-top: 16px;">Dilediğin zaman çıkabilirsin. Gizliliğine saygı duyuyoruz.</p>
        </div>
    </div>
</section>

<style>
@keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
#newsletter-form input:focus {
    border-color: rgba(108,99,255,0.5);
    box-shadow: 0 0 20px rgba(108,99,255,0.1);
}
</style>

<%- include('../partials/footer') %>

