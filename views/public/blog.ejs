<%- include('../partials/header') %>

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-bg">
        <div class="gradient-orb gradient-orb-1"></div>
        <div class="gradient-orb gradient-orb-2"></div>
    </div>
    <div class="container">
        <div class="page-hero-content">
            <span class="section-tag">Yazılarımız</span>
            <h1 class="page-hero-title">Blog</h1>
            <p class="page-hero-subtitle">Sektörel gelişmeler, uzman görüşleri ve faydalı bilgiler.</p>
        </div>
    </div>
</section>

<!-- Blog Listesi -->
<section class="blog-list section">
    <div class="container">
        <% if (typeof posts !== 'undefined' && posts && posts.length > 0) { %>
            <div class="blog-grid blog-grid-full">
                <% posts.forEach(function(post) { %>
                    <article class="blog-card glass-card">
                        <% if (post.cover_image) { %>
                            <div class="blog-card-image">
                                <img src="<%= post.cover_image %>" alt="<%= post.title %>" loading="lazy">
                            </div>
                        <% } else { %>
                            <div class="blog-card-image blog-card-image-placeholder">
                                <div class="placeholder-icon">📝</div>
                            </div>
                        <% } %>
                        <div class="blog-card-body">
                            <div class="blog-card-meta">
                                <span class="blog-card-date">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                        <line x1="16" y1="2" x2="16" y2="6"/>
                                        <line x1="8" y1="2" x2="8" y2="6"/>
                                        <line x1="3" y1="10" x2="21" y2="10"/>
                                    </svg>
                                    <%= post.created_at ? new Date(post.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) : '' %>
                                </span>
                                <% if (post.author) { %>
                                    <span class="blog-card-author">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                            <circle cx="12" cy="7" r="4"/>
                                        </svg>
                                        <%= post.author %>
                                    </span>
                                <% } %>
                            </div>
                            <h3 class="blog-card-title">
                                <a href="/blog/<%= post.slug %>"><%= post.title %></a>
                            </h3>
                            <p class="blog-card-excerpt"><%= post.excerpt || '' %></p>
                            <a href="/blog/<%= post.slug %>" class="blog-card-link">
                                Devamını Oku
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"/>
                                    <polyline points="12 5 19 12 12 19"/>
                                </svg>
                            </a>
                        </div>
                    </article>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-state-icon">📝</div>
                <h3 class="empty-state-title">Henüz Blog Yazısı Yok</h3>
                <p class="empty-state-text">Henüz blog yazısı bulunmuyor. Yakında yeni içeriklerle burada olacağız!</p>
            </div>
        <% } %>
    </div>
</section>

<%- include('../partials/footer') %>
