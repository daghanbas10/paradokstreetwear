<%- include('partials/admin-header') %>

<!-- Mesajlar Başlık -->
<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h2 class="admin-page-title">Mesajlar</h2>
        <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
            <span class="badge badge-warning"><%= unreadCount %> Okunmamış</span>
        <% } %>
    </div>
</div>

<!-- Mesaj Listesi -->
<div class="messages-list">
    <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
        <% messages.forEach(function(msg) { %>
            <div class="message-card glass-card-admin <%= msg.is_read ? '' : 'message-unread' %>" data-message-id="<%= msg.id %>">
                <div class="message-card-header" onclick="toggleMessage(this)">
                    <div class="message-card-info">
                        <div class="message-sender">
                            <div class="message-avatar">
                                <%= msg.name ? msg.name.charAt(0).toUpperCase() : '?' %>
                            </div>
                            <div class="message-sender-details">
                                <span class="message-sender-name"><%= msg.name %></span>
                                <span class="message-sender-email"><%= msg.email %></span>
                            </div>
                        </div>
                        <div class="message-subject-row">
                            <span class="message-subject"><%= msg.subject %></span>
                            <% if (!msg.is_read) { %>
                                <span class="badge badge-warning badge-sm">Yeni</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="message-card-meta">
                        <span class="message-date">
                            <%= msg.created_at ? new Date(msg.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '' %>
                        </span>
                        <div class="message-status">
                            <% if (msg.is_read) { %>
                                <span class="badge badge-success badge-sm">Okundu</span>
                            <% } else { %>
                                <span class="badge badge-warning badge-sm">Okunmamış</span>
                            <% } %>
                        </div>
                        <button class="message-toggle-btn" aria-label="Mesajı aç/kapat">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="message-card-body" style="display: none;">
                    <div class="message-content">
                        <% if (msg.phone) { %>
                            <div class="message-phone">
                                <strong>Telefon:</strong> <%= msg.phone %>
                            </div>
                        <% } %>
                        <div class="message-text">
                            <p><%= msg.message %></p>
                        </div>
                    </div>
                    <div class="message-actions">
                        <% if (!msg.is_read) { %>
                            <form action="/admin/messages/<%= msg.id %>/read" method="POST" class="inline-form">
                                <button type="submit" class="btn-admin btn-admin-sm btn-admin-success">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Okundu İşaretle
                                </button>
                            </form>
                        <% } %>
                        <form action="/admin/messages/<%= msg.id %>?_method=DELETE" method="POST" class="inline-form" onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?')">
                            <button type="submit" class="btn-admin btn-admin-sm btn-admin-danger">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"/>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    <line x1="10" y1="11" x2="10" y2="17"/>
                                    <line x1="14" y1="11" x2="14" y2="17"/>
                                </svg>
                                Sil
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="admin-empty-state glass-card-admin">
            <div class="admin-empty-icon">📭</div>
            <h3 class="admin-empty-title">Henüz Mesaj Yok</h3>
            <p class="admin-empty-text">Henüz mesaj bulunmuyor. Yeni mesajlar burada görünecektir.</p>
        </div>
    <% } %>
</div>

<script>
function toggleMessage(header) {
    const card = header.closest('.message-card');
    const body = card.querySelector('.message-card-body');
    const toggleBtn = card.querySelector('.message-toggle-btn svg');
    
    if (body.style.display === 'none') {
        body.style.display = 'block';
        toggleBtn.style.transform = 'rotate(180deg)';
        card.classList.add('message-expanded');
    } else {
        body.style.display = 'none';
        toggleBtn.style.transform = 'rotate(0deg)';
        card.classList.remove('message-expanded');
    }
}
</script>

<%- include('partials/admin-footer') %>
