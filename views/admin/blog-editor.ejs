<%- include('partials/admin-header') %>

<!-- Blog Editor Başlık -->
<div class="admin-page-header">
    <div class="admin-page-header-left">
        <h2 class="admin-page-title">
            <% if (typeof post !== 'undefined' && post) { %>
                Yazıyı Düzenle
            <% } else { %>
                Yeni Yazı
            <% } %>
        </h2>
    </div>
    <div class="admin-page-header-right">
        <a href="/admin/blog" class="btn-admin btn-admin-outline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Geri Dön
        </a>
    </div>
</div>

<!-- Blog Editor Form -->
<div class="blog-editor glass-card-admin">
    <form 
        action="<%= typeof post !== 'undefined' && post ? '/admin/blog/' + post.id : '/admin/blog' %>" 
        method="POST" 
        enctype="multipart/form-data"
        class="blog-editor-form"
    >
        <!-- Başlık -->
        <div class="admin-form-group">
            <label for="title" class="admin-form-label">
                Başlık <span class="required">*</span>
            </label>
            <input 
                type="text" 
                id="title" 
                name="title" 
                class="admin-form-input" 
                placeholder="Yazı başlığını girin" 
                value="<%= typeof post !== 'undefined' && post ? post.title : '' %>" 
                required
            >
        </div>

        <!-- Kapak Resmi -->
        <div class="admin-form-group">
            <label for="cover_image" class="admin-form-label">Kapak Resmi</label>
            
            <% if (typeof post !== 'undefined' && post && post.cover_image) { %>
                <div class="current-cover-image">
                    <img src="<%= post.cover_image %>" alt="Mevcut kapak resmi" class="cover-preview">
                    <span class="cover-preview-label">Mevcut kapak resmi</span>
                </div>
            <% } %>
            
            <div class="file-upload-wrapper">
                <input type="file" id="cover_image" name="cover_image" class="file-upload-input" accept="image/*">
                <label for="cover_image" class="file-upload-label">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    <span class="file-upload-text">
                        <% if (typeof post !== 'undefined' && post && post.cover_image) { %>
                            Yeni resim seçin (değiştirmek için)
                        <% } else { %>
                            Kapak resmi seçin
                        <% } %>
                    </span>
                    <span class="file-upload-hint">PNG, JPG, WEBP - Maks. 5MB</span>
                </label>
            </div>
        </div>

        <!-- Özet -->
        <div class="admin-form-group">
            <label for="excerpt" class="admin-form-label">Özet / Kısa Açıklama</label>
            <textarea 
                id="excerpt" 
                name="excerpt" 
                class="admin-form-textarea" 
                rows="3" 
                placeholder="Yazının kısa özetini girin (blog listesinde görünecek)"
            ><%= typeof post !== 'undefined' && post && post.excerpt ? post.excerpt : '' %></textarea>
        </div>

        <!-- İçerik -->
        <div class="admin-form-group">
            <label for="content" class="admin-form-label">
                İçerik <span class="required">*</span>
            </label>
            <textarea 
                id="content" 
                name="content" 
                class="admin-form-textarea admin-form-textarea-lg" 
                rows="15" 
                placeholder="Yazı içeriğini buraya girin. HTML etiketleri kullanabilirsiniz."
                required
            ><%= typeof post !== 'undefined' && post && post.content ? post.content : '' %></textarea>
            <span class="admin-form-hint">HTML etiketleri desteklenir. Paragraflar için &lt;p&gt;, başlıklar için &lt;h2&gt;, &lt;h3&gt; kullanabilirsiniz.</span>
        </div>

        <!-- Yayın Durumu -->
        <div class="admin-form-group">
            <div class="admin-checkbox-wrapper">
                <input 
                    type="checkbox" 
                    id="is_published" 
                    name="is_published" 
                    class="admin-checkbox" 
                    value="1"
                    <%= typeof post !== 'undefined' && post && post.is_published ? 'checked' : '' %>
                >
                <label for="is_published" class="admin-checkbox-label">
                    <div class="checkbox-custom">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <div class="checkbox-text">
                        <span class="checkbox-title">Yayınla</span>
                        <span class="checkbox-desc">İşaretlenirse yazı sitede görünür olacaktır.</span>
                    </div>
                </label>
            </div>
        </div>

        <!-- Submit -->
        <div class="admin-form-actions">
            <button type="submit" class="btn-admin btn-admin-primary btn-admin-lg">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                <% if (typeof post !== 'undefined' && post) { %>
                    Yazıyı Güncelle
                <% } else { %>
                    Yazıyı Kaydet
                <% } %>
            </button>
            <a href="/admin/blog" class="btn-admin btn-admin-outline">İptal</a>
        </div>
    </form>
</div>

<%- include('partials/admin-footer') %>
