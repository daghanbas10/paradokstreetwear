<%- include('partials/admin-header') %>

<!-- Dashboard Content -->
<div class="dashboard-stats">
    <!-- Toplam Mesaj -->
    <div class="stat-card-admin glass-card-admin">
        <div class="stat-card-icon stat-icon-primary">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
            </svg>
        </div>
        <div class="stat-card-body">
            <span class="stat-card-number"><%= typeof totalMessages !== 'undefined' ? totalMessages : 0 %></span>
            <span class="stat-card-label">Toplam Mesaj</span>
        </div>
    </div>

    <!-- Okunmamış -->
    <div class="stat-card-admin glass-card-admin">
        <div class="stat-card-icon stat-icon-secondary">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
        </div>
        <div class="stat-card-body">
            <span class="stat-card-number"><%= typeof unreadMessages !== 'undefined' ? unreadMessages : 0 %></span>
            <span class="stat-card-label">Okunmamış Mesaj</span>
        </div>
    </div>

    <!-- Blog Yazıları -->
    <div class="stat-card-admin glass-card-admin">
        <div class="stat-card-icon stat-icon-accent">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
        </div>
        <div class="stat-card-body">
            <span class="stat-card-number"><%= typeof totalPosts !== 'undefined' ? totalPosts : 0 %></span>
            <span class="stat-card-label">Blog Yazısı</span>
        </div>
    </div>

    <!-- Üye Sayısı -->
    <div class="stat-card-admin glass-card-admin">
        <div class="stat-card-icon" style="background: rgba(163,177,138,0.15); color: #A3B18A;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <div class="stat-card-body">
            <span class="stat-card-number"><%= typeof totalMembers !== 'undefined' ? totalMembers : 0 %></span>
            <span class="stat-card-label">Kayıtlı Üye</span>
        </div>
    </div>
</div>

<!-- Hızlı Erişim -->
<div class="admin-section">
    <h2 class="admin-section-title" style="margin-bottom: 1rem;">⚡ Hızlı Erişim</h2>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
        <a href="/admin/blog/new" style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; text-decoration: none; color: #FFFFFE; transition: all 0.3s ease;">
            <span style="font-size: 1.4rem;">📝</span>
            <span style="font-size: 0.85rem; font-weight: 500;">Yeni Blog Yazısı</span>
        </a>
        <a href="/admin/members" style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; text-decoration: none; color: #FFFFFE; transition: all 0.3s ease;">
            <span style="font-size: 1.4rem;">👥</span>
            <span style="font-size: 0.85rem; font-weight: 500;">Üyeleri Görüntüle</span>
        </a>
        <a href="/admin/members/export" style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; text-decoration: none; color: #FFFFFE; transition: all 0.3s ease;">
            <span style="font-size: 1.4rem;">📥</span>
            <span style="font-size: 0.85rem; font-weight: 500;">CSV İndir</span>
        </a>
        <a href="/admin/messages" style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; text-decoration: none; color: #FFFFFE; transition: all 0.3s ease;">
            <span style="font-size: 1.4rem;">📧</span>
            <span style="font-size: 0.85rem; font-weight: 500;">Mesajları Kontrol Et</span>
        </a>
        <a href="/admin/content" style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; text-decoration: none; color: #FFFFFE; transition: all 0.3s ease;">
            <span style="font-size: 1.4rem;">⚙️</span>
            <span style="font-size: 0.85rem; font-weight: 500;">Site İçerikleri</span>
        </a>
        <a href="/admin/settings" style="display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; text-decoration: none; color: #FFFFFE; transition: all 0.3s ease;">
            <span style="font-size: 1.4rem;">🔐</span>
            <span style="font-size: 0.85rem; font-weight: 500;">Hesap Ayarları</span>
        </a>
    </div>
</div>

<!-- Sistem Bilgisi -->
<div class="admin-section">
    <div class="glass-card-admin" style="padding: 20px 24px;">
        <div style="display: flex; flex-wrap: wrap; gap: 24px; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="width: 8px; height: 8px; border-radius: 50%; background: #22C55E; display: inline-block;"></span>
                <span style="color: #A7A9BE; font-size: 0.8rem;">Sunucu: <strong style="color: #22C55E;">Aktif</strong></span>
            </div>
            <div style="color: #A7A9BE; font-size: 0.8rem;">Platform: <strong style="color: #FFFFFE;">Render.com</strong></div>
            <div style="color: #A7A9BE; font-size: 0.8rem;">Giriş: <strong style="color: #FFFFFE;"><%= typeof adminUsername !== 'undefined' ? adminUsername : 'Admin' %></strong></div>
            <div style="color: #A7A9BE; font-size: 0.8rem;">Tarih: <strong style="color: #FFFFFE;"><%= new Date().toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }) %></strong></div>
            <a href="/" target="_blank" style="margin-left: auto; color: #6C63FF; text-decoration: none; font-size: 0.8rem; font-weight: 600;">🌐 Siteyi Gör →</a>
        </div>
    </div>
</div>

<style>
.admin-section a[href]:hover { background: rgba(108,99,255,0.1) !important; border-color: rgba(108,99,255,0.3) !important; transform: translateY(-2px); }
@media (max-width: 768px) { .admin-section div[style*="grid-template-columns: repeat(3"] { grid-template-columns: repeat(2, 1fr) !important; } }
</style>

<!-- Son Mesajlar Tablosu -->
<div class="admin-section">
    <div class="admin-section-header">
        <h2 class="admin-section-title">Son Mesajlar</h2>
        <a href="/admin/messages" class="admin-section-link">
            Tüm Mesajları Gör
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
            </svg>
        </a>
    </div>
    <div class="admin-table-wrapper glass-card-admin">
        <% if (typeof recentMessages !== 'undefined' && recentMessages && recentMessages.length > 0) { %>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Gönderen</th>
                        <th>Konu</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    <% recentMessages.slice(0, 5).forEach(function(msg) { %>
                        <tr>
                            <td>
                                <div class="table-user">
                                    <span class="table-user-name"><%= msg.name %></span>
                                    <span class="table-user-email"><%= msg.email %></span>
                                </div>
                            </td>
                            <td><span class="table-subject"><%= msg.subject %></span></td>
                            <td>
                                <span class="table-date">
                                    <%= msg.created_at ? new Date(msg.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'short', day: 'numeric' }) : '' %>
                                </span>
                            </td>
                            <td>
                                <% if (msg.is_read) { %>
                                    <span class="badge badge-success">Okundu</span>
                                <% } else { %>
                                    <span class="badge badge-warning">Okunmamış</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div class="admin-empty-state">
                <div class="admin-empty-icon">📭</div>
                <p class="admin-empty-text">Henüz mesaj bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Son Üyeler Tablosu -->
<div class="admin-section">
    <div class="admin-section-header">
        <h2 class="admin-section-title">Son Kayıt Olan Üyeler</h2>
        <a href="/admin/members" class="admin-section-link">
            Tüm Üyeleri Gör
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
            </svg>
        </a>
    </div>
    <div class="admin-table-wrapper glass-card-admin">
        <% if (typeof recentMembers !== 'undefined' && recentMembers && recentMembers.length > 0) { %>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Kategori</th>
                        <th>Beden</th>
                        <th>Kayıt</th>
                    </tr>
                </thead>
                <tbody>
                    <% recentMembers.forEach(function(m) { %>
                        <tr>
                            <td><span class="table-user-name"><%= m.name %></span></td>
                            <td><span class="table-user-email"><%= m.email %></span></td>
                            <td><span class="badge badge-info"><%= m.category === 'erkek' ? '👔 Erkek' : m.category === 'kadin' ? '🌸 Kadın' : m.category === 'hepsi' ? '🔥 Hepsi' : '—' %></span></td>
                            <td><%= m.size ? m.size.toUpperCase() : '—' %></td>
                            <td>
                                <span class="table-date">
                                    <%= m.created_at ? new Date(m.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'short', day: 'numeric' }) : '' %>
                                </span>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div class="admin-empty-state">
                <div class="admin-empty-icon">👥</div>
                <p class="admin-empty-text">Henüz kayıtlı üye bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/admin-footer') %>
