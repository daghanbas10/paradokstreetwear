<%- include('partials/admin-header') %>

<!-- Dashboard Content -->
<div class="dashboard-stats">
    <!-- Toplam Mesaj -->
    <div class="stat-card-admin glass-card-admin">
        <div class="stat-card-icon stat-icon-primary">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
            </svg>
        </div>
        <div class="stat-card-body">
            <span class="stat-card-number"><%= typeof totalMessages !== 'undefined' ? totalMessages : 0 %></span>
            <span class="stat-card-label">Toplam Mesaj</span>
        </div>
    </div>

    <!-- Okunmamış -->
    <div class="stat-card-admin glass-card-admin">
        <div class="stat-card-icon stat-icon-secondary">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
        </div>
        <div class="stat-card-body">
            <span class="stat-card-number"><%= typeof unreadMessages !== 'undefined' ? unreadMessages : 0 %></span>
            <span class="stat-card-label">Okunmamış Mesaj</span>
        </div>
    </div>

    <!-- Blog Yazıları -->
    <div class="stat-card-admin glass-card-admin">
        <div class="stat-card-icon stat-icon-accent">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
        </div>
        <div class="stat-card-body">
            <span class="stat-card-number"><%= typeof totalPosts !== 'undefined' ? totalPosts : 0 %></span>
            <span class="stat-card-label">Blog Yazısı</span>
        </div>
    </div>
</div>

<!-- Son Mesajlar Tablosu -->
<div class="admin-section">
    <div class="admin-section-header">
        <h2 class="admin-section-title">Son Mesajlar</h2>
        <a href="/admin/messages" class="admin-section-link">
            Tüm Mesajları Gör
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
            </svg>
        </a>
    </div>
    <div class="admin-table-wrapper glass-card-admin">
        <% if (typeof recentMessages !== 'undefined' && recentMessages && recentMessages.length > 0) { %>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Gönderen</th>
                        <th>Konu</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    <% recentMessages.slice(0, 5).forEach(function(msg) { %>
                        <tr>
                            <td>
                                <div class="table-user">
                                    <span class="table-user-name"><%= msg.name %></span>
                                    <span class="table-user-email"><%= msg.email %></span>
                                </div>
                            </td>
                            <td><span class="table-subject"><%= msg.subject %></span></td>
                            <td>
                                <span class="table-date">
                                    <%= msg.created_at ? new Date(msg.created_at).toLocaleDateString('tr-TR', { year: 'numeric', month: 'short', day: 'numeric' }) : '' %>
                                </span>
                            </td>
                            <td>
                                <% if (msg.is_read) { %>
                                    <span class="badge badge-success">Okundu</span>
                                <% } else { %>
                                    <span class="badge badge-warning">Okunmamış</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div class="admin-empty-state">
                <div class="admin-empty-icon">📭</div>
                <p class="admin-empty-text">Henüz mesaj bulunmuyor.</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/admin-footer') %>
