<%- include('partials/admin-header') %>

<div class="admin-page-header">
    <h2 class="admin-page-title">🔧 Hesap Ayarları</h2>
    <p class="admin-page-subtitle">Hesap bilgilerinizi görüntüleyin ve yönetin.</p>
</div>

<!-- Hesap Bilgileri -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px;">
    <div class="glass-card-admin" style="padding: 28px;">
        <h3 style="color: #FFFFFE; font-family: 'Outfit', sans-serif; font-size: 1rem; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 1.2rem;">👤</span> Hesap Bilgileri
        </h3>
        <div style="display: flex; flex-direction: column; gap: 16px;">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px;">
                <span style="color: #A7A9BE; font-size: 0.85rem;">Kullanıcı Adı</span>
                <span style="color: #FFFFFE; font-weight: 600;"><%= typeof adminUsername !== 'undefined' ? adminUsername : 'Admin' %></span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px;">
                <span style="color: #A7A9BE; font-size: 0.85rem;">Yetki</span>
                <span style="color: #6C63FF; font-weight: 600;">Süper Admin</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px;">
                <span style="color: #A7A9BE; font-size: 0.85rem;">Hesap Durumu</span>
                <span style="color: #22C55E; font-weight: 600;">✅ Aktif</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px;">
                <span style="color: #A7A9BE; font-size: 0.85rem;">Son Giriş</span>
                <span style="color: #FFFFFE; font-weight: 500; font-size: 0.85rem;"><%= new Date().toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
            </div>
        </div>
    </div>

    <!-- Hızlı Linkler -->
    <div class="glass-card-admin" style="padding: 28px;">
        <h3 style="color: #FFFFFE; font-family: 'Outfit', sans-serif; font-size: 1rem; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 1.2rem;">🔗</span> Hızlı Linkler
        </h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <a href="/" target="_blank" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; color: #FFFFFE; text-decoration: none; font-size: 0.85rem; transition: all 0.3s ease;">🌐 Siteyi Gör</a>
            <a href="/admin/dashboard" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; color: #FFFFFE; text-decoration: none; font-size: 0.85rem; transition: all 0.3s ease;">📊 Dashboard</a>
            <a href="/admin/members" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; color: #FFFFFE; text-decoration: none; font-size: 0.85rem; transition: all 0.3s ease;">👥 Üyeler</a>
            <a href="/admin/members/export" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; color: #FFFFFE; text-decoration: none; font-size: 0.85rem; transition: all 0.3s ease;">📥 CSV Export</a>
            <a href="/admin/blog" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; color: #FFFFFE; text-decoration: none; font-size: 0.85rem; transition: all 0.3s ease;">📝 Blog</a>
            <a href="/admin/messages" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.03); border-radius: 10px; color: #FFFFFE; text-decoration: none; font-size: 0.85rem; transition: all 0.3s ease;">📧 Mesajlar</a>
        </div>
    </div>
</div>

<!-- Şifre Değiştir -->
<div class="glass-card-admin" style="padding: 28px; max-width: 560px; margin-bottom: 24px;">
    <h3 style="color: #FFFFFE; font-family: 'Outfit', sans-serif; font-size: 1rem; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 1.2rem;">🔐</span> Şifre Değiştir
    </h3>

    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
        <div style="background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); border-radius: 10px; padding: 12px 16px; margin-bottom: 16px; color: #22C55E; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;">
            ✅ <%= successMessage %>
        </div>
    <% } %>
    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div style="background: rgba(255,101,132,0.1); border: 1px solid rgba(255,101,132,0.3); border-radius: 10px; padding: 12px 16px; margin-bottom: 16px; color: #FF6584; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;">
            ⚠️ <%= errorMessage %>
        </div>
    <% } %>

    <form action="/admin/settings" method="POST">
        <div style="margin-bottom: 16px;">
            <label style="display: block; color: #A7A9BE; font-size: 0.8rem; font-weight: 500; margin-bottom: 6px;">Mevcut Şifre</label>
            <input type="password" name="currentPassword" required placeholder="Mevcut şifrenizi girin" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #FFFFFE; font-family: 'Inter', sans-serif; font-size: 0.9rem; outline: none; box-sizing: border-box; transition: border-color 0.3s;">
        </div>
        <div style="margin-bottom: 16px;">
            <label style="display: block; color: #A7A9BE; font-size: 0.8rem; font-weight: 500; margin-bottom: 6px;">Yeni Şifre</label>
            <input type="password" name="newPassword" required minlength="6" placeholder="En az 6 karakter" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #FFFFFE; font-family: 'Inter', sans-serif; font-size: 0.9rem; outline: none; box-sizing: border-box; transition: border-color 0.3s;">
        </div>
        <div style="margin-bottom: 20px;">
            <label style="display: block; color: #A7A9BE; font-size: 0.8rem; font-weight: 500; margin-bottom: 6px;">Yeni Şifre (Tekrar)</label>
            <input type="password" name="confirmPassword" required minlength="6" placeholder="Yeni şifreyi tekrar girin" style="width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: #FFFFFE; font-family: 'Inter', sans-serif; font-size: 0.9rem; outline: none; box-sizing: border-box; transition: border-color 0.3s;">
        </div>
        <button type="submit" style="width: 100%; padding: 14px; background: linear-gradient(135deg, #6C63FF, #FF6584); border: none; border-radius: 12px; color: #FFFFFE; font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">
            Şifreyi Güncelle
        </button>
    </form>
</div>

<!-- Tehlikeli Bölge -->
<div style="background: rgba(255,101,132,0.05); border: 1px solid rgba(255,101,132,0.15); border-radius: 16px; padding: 28px; max-width: 560px;">
    <h3 style="color: #FF6584; font-family: 'Outfit', sans-serif; font-size: 1rem; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
        <span style="font-size: 1.2rem;">⚠️</span> Tehlikeli Bölge
    </h3>
    <p style="color: #A7A9BE; font-size: 0.82rem; line-height: 1.6; margin-bottom: 16px;">
        Aşağıdaki işlem oturumunuzu sonlandırır ve giriş ekranına yönlendirir. Kaydedilmemiş değişiklikleriniz kaybolabilir.
    </p>
    <a href="/admin/logout" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: rgba(255,101,132,0.15); color: #FF6584; border: 1px solid rgba(255,101,132,0.3); border-radius: 10px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.3s ease;"
       onclick="return confirm('Oturumunuz sonlandırılacak. Emin misiniz?')">
        🚪 Oturumu Sonlandır
    </a>
</div>

<style>
.glass-card-admin a[href]:hover { background: rgba(108,99,255,0.1) !important; }
input:focus { border-color: #6C63FF !important; box-shadow: 0 0 0 3px rgba(108,99,255,0.15); }
@media (max-width: 768px) {
    div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
}
</style>

<%- include('partials/admin-footer') %>
